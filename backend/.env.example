# Backend Environment Variables — ZANXA Tech

# Server
PORT=5000
NODE_ENV=production
# Production: The URL of your frontend (e.g., https://zanxatech.vercel.app)
FRONTEND_URL=http://localhost:3000

# Database
# Production: Connection string from Supabase/Neon/Railway
DATABASE_URL=
# Required for connection pooling on some platforms
DIRECT_URL=

# JWT
# Generate a secret: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin Credentials (Initial seed)
ADMIN_EMAIL=admin@zanxatech.com
ADMIN_PASSWORD=

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Zanxa Tech <no-reply@zanxatech.com>"

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin
# IMPORTANT: Convert your Service Account JSON to a Base64 string for production.
# Command: cat service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=

# Supabase Storage (Optional if using for large assets)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_CERTIFICATES_BUCKET=certificates
