# Environment Variables — Zanxa Tech Backend

# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zanxatech"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Admin Credentials (seeded)
ADMIN_EMAIL="admin@zanxatech.com"
ADMIN_PASSWORD="ZanxaAdmin@2024"

# Email (Gmail SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="zanxatech@gmail.com"
SMTP_PASS="your-gmail-app-password"
EMAIL_FROM="Zanxa Tech <zanxatech@gmail.com>"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# Cloudinary (Sign up at cloudinary.com)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Firebase Admin (Get Service Account JSON from Firebase Console)
# Format: Paste the entire JSON as a single line string or provide project ID for ADC
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "...", ...}'
FIREBASE_PROJECT_ID="your-project-id"

# Supabase Storage Bucket
SUPABASE_CERTIFICATES_BUCKET="certificates"
